// 1. Iterate through the array
// 2. Store the elements that are not equal to val back in the array
// 3. If the element is equal to val, then skip storing
// 4. Retuen the last index of the new nums array

// T.C = O(N)
// S.C = O(1) : index variable is new
int removeElement(int* nums, int numsSize, int val) {
    
    int index = 0;
    for(int i = 0; i < numsSize; i++)
    {
        if(nums[i] != val)
        {
            nums[index] = nums[i];
            index++;
        }
    }

    return index;
}
